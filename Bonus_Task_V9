import os
os.environ['CUDA_VISIBLE_DEVICES'] = '-1'

import tensorflow as tf
from tensorflow import keras
from tensorflow.keras import layers, models, datasets, callbacks
import numpy as np
import time

# Фиксируем seed
tf.random.set_seed(42)
np.random.seed(42)

print("TensorFlow использует устройства:", tf.config.list_physical_devices())
print("Работаем на CPU.\n")

# -------------------------------------------------------------------
# 1. Загрузка данных (те же самые)
# -------------------------------------------------------------------
print("Загрузка данных CIFAR-10...")
(x_train_full, y_train_full), (x_test, y_test) = datasets.cifar10.load_data()

x_train_full = x_train_full.astype('float32') / 255.0
x_test = x_test.astype('float32') / 255.0

y_train_full = keras.utils.to_categorical(y_train_full, 10)
y_test = keras.utils.to_categorical(y_test, 10)

from sklearn.model_selection import train_test_split
x_train, x_val, y_train, y_val = train_test_split(
    x_train_full, y_train_full, test_size=0.1, random_state=42
)

print(f"Размеры: train {x_train.shape}, val {x_val.shape}, test {x_test.shape}")

# -------------------------------------------------------------------
# 2. Функция создания модели с Dropout
# -------------------------------------------------------------------
def create_model_with_dropout(dropout_rate):
    model = models.Sequential([
        layers.Conv2D(32, (3,3), padding='same', activation='relu', input_shape=(32,32,3)),
        layers.BatchNormalization(),
        layers.Conv2D(32, (3,3), padding='same', activation='relu'),
        layers.BatchNormalization(),
        layers.MaxPooling2D((2,2)),
        layers.Dropout(dropout_rate),   # пространственный Dropout после пулинга

        layers.Conv2D(64, (3,3), padding='same', activation='relu'),
        layers.BatchNormalization(),
        layers.Conv2D(64, (3,3), padding='same', activation='relu'),
        layers.BatchNormalization(),
        layers.MaxPooling2D((2,2)),
        layers.Dropout(dropout_rate),

        layers.Conv2D(128, (3,3), padding='same', activation='relu'),
        layers.BatchNormalization(),
        layers.Conv2D(128, (3,3), padding='same', activation='relu'),
        layers.BatchNormalization(),
        layers.MaxPooling2D((2,2)),
        layers.Dropout(dropout_rate),

        layers.GlobalAveragePooling2D(),
        layers.Dense(10, activation='softmax')
    ])
    return model

# -------------------------------------------------------------------
# 3. Подбор параметра dropout
# -------------------------------------------------------------------
dropout_rates = [0.0, 0.2, 0.3, 0.5, 0.7]
results = {}

print("\n=== Эксперименты с Dropout ===")

for dr in dropout_rates:
    print(f"\n--- Обучение модели с dropout = {dr} ---")
    model = create_model_with_dropout(dr)
    model.compile(optimizer='adam',
                  loss='categorical_crossentropy',
                  metrics=['accuracy'])

    early_stop = callbacks.EarlyStopping(monitor='val_accuracy', patience=10, restore_best_weights=True, verbose=0)
    reduce_lr = callbacks.ReduceLROnPlateau(monitor='val_accuracy', factor=0.5, patience=5, verbose=0)

    start_time = time.time()
    history = model.fit(
        x_train, y_train,
        batch_size=128,
        epochs=50,
        validation_data=(x_val, y_val),
        callbacks=[early_stop, reduce_lr],
        verbose=1   # показываем прогресс, чтобы видеть, что обучение идёт
    )
    elapsed = time.time() - start_time

    test_loss, test_acc = model.evaluate(x_test, y_test, verbose=0)
    results[dr] = test_acc
    print(f"Dropout {dr}: точность = {test_acc:.4f}, время = {elapsed/60:.1f} мин.")

# -------------------------------------------------------------------
# 4. Анализ результатов
# -------------------------------------------------------------------
print("\n=== Сравнение точности на тесте ===")
for dr, acc in results.items():
    print(f"Dropout {dr}: {acc:.4f}")

best_dr = max(results, key=results.get)
best_acc = results[best_dr]
print(f"\nЛучший параметр Dropout: {best_dr} с точностью {best_acc:.4f}")

# Сравнение с базовой моделью (dropout=0.0)
base_acc = results[0.0]
if best_dr != 0.0:
    improvement = best_acc - base_acc
    if improvement > 0:
        print(f"Улучшение на {improvement:.4f} ({improvement*100:.2f}%) по сравнению с базовой моделью.")
    else:
        print(f"Ухудшение на {abs(improvement):.4f} ({abs(improvement)*100:.2f}%).")
else:
    print("Базовая модель (без dropout) показала наилучший результат.")

print("\nВывод: Dropout помогает бороться с переобучением, но при слишком высоком коэффициенте")
print("(например, 0.7) может ухудшить точность. Оптимальное значение для данной архитектуры –",
      best_dr if best_dr != 0.0 else "0.0 (т.е. без dropout)")

# Сохраняем лучшую модель
best_model = create_model_with_dropout(best_dr)
best_model.compile(optimizer='adam', loss='categorical_crossentropy', metrics=['accuracy'])
